# 搜索关键词列表，使用英文逗号分隔
KEYWORDS=教育培训

# 目标城市/地区列表，使用英文逗号分隔；REGIONS 和 DEFAULT_REGIONS 都为空时表示不限地区
REGIONS=
DEFAULT_REGIONS=

# 每个“关键词 + 城市”最多抓取页数
MAX_PAGES_PER_REGION=5
MAX_EMPTY_PAGE_RETRIES=2

# 浏览器行为
HEADLESS=false
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
VIEWPORT_WIDTH=1400
VIEWPORT_HEIGHT=900

# 随机延时区间，单位：秒
DELAY_AFTER_OPEN_SEARCH=1.0,2.0
DELAY_BETWEEN_PAGES=0.8,1.5
DELAY_RETRY_RELOAD=2.5,4.0
DELAY_BETWEEN_TASKS=2.5,4.5
DELAY_BEFORE_NEXT_PAGE=0.5,1.0
DELAY_AFTER_NEXT_PAGE=1.0,1.8
DELAY_LONG_BREAK=6.0,10.0
DELAY_BEFORE_OPEN_DETAIL=0.8,1.6
DELAY_AFTER_OPEN_DETAIL=1.8,3.0
DELAY_BETWEEN_DETAILS=0.9,1.8
DELAY_DETAIL_RETRY=2.5,4.5

LONG_BREAK_EVERY_PAGES=5
LONG_BREAK_PROBABILITY=0.2
RETRY_BACKOFF_FACTOR=1.7
MAX_RETRY_DELAY_SECONDS=36.0
MAX_DETAIL_RETRIES=1
DETAIL_PAGE_TIMEOUT_MS=90000
TYPE_DELAY_MS=40,100

OUTPUT_DIR=output
CRAWLED_LINKS_DIR=output/crawled_links

# false 会逐条打开岗位详情页补全“工作内容/任职要求”；true 只导出列表页字段，速度更快但详情为空
SKIP_DETAIL_FETCH=false
# true 会忽略历史详情链接记录，适合列表导出后再回补详情
REFETCH_CRAWLED_DETAILS=false

# 招聘平台：zhaopin 或 51job
PLATFORM=zhaopin

# 51job 使用真实浏览器 Profile 保存手机号/短信验证码登录状态
LOGIN_51JOB=false
USER_DATA_DIR=auth/51job_profile
AUTH_WAIT_SECONDS=300

# Zhaopin can reuse a persistent browser profile and pause for manual verification.
LOGIN_ZHAOPIN=false
ZHAOPIN_USER_DATA_DIR=auth/zhaopin_profile
MANUAL_AUTH=true

# Browser backend: playwright, scrapling, gologin, adspower, or orbita_cdp
# 当前主流程使用 orbita_cdp：启动本机 GoLogin 下载的 Orbita，再通过 CDP 接管
BROWSER_BACKEND=orbita_cdp

# Gologin API 配置（仅当 BROWSER_BACKEND=gologin 时需要；orbita_cdp 主流程留空即可）
# API Token 获取: https://app.gologin.com/#/personalArea/TokenApi
GOLOGIN_TOKEN=
# Profile ID（可选，不填则每次自动创建临时指纹；建议手动创建后填入以复用登录状态）
GOLOGIN_PROFILE_ID=

SCRAPLING_REAL_CHROME=false
SCRAPLING_GOOGLE_SEARCH=false
SCRAPLING_BLOCK_WEBRTC=true
SCRAPLING_HIDE_CANVAS=true

# YesCaptcha API 配置 - 用于自动解决人机验证
# 注册地址: https://yescaptcha.atlassian.net/wiki/spaces/YESCAPTCHA/pages/63897603/YesCaptcha+API
YESCAPTCHA_API_KEY=your_yescaptcha_api_key_here
